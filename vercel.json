{
  "version": 2,
  "builds": [
    {
      "src": "src/vercel-entry.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 300,
        "runtime": "nodejs20.x"
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "src/vercel-entry.ts" }
  ],
  "env": {
    "REDIS_URL": "",
    "MONGODB_URI": "",
    "SESSION_NUMBERS": "",
    "PORT": "3000",
    "ROTATION_COUNT": "1000"
  }
}
