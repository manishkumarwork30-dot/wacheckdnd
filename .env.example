# .env.example
# Meta Business API credentials (Option A)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_meta_access_token
META_BUSINESS_ID=your_meta_business_id

# Database connection (PostgreSQL or MongoDB)
DB_CONNECTION_STRING=your_database_connection_string

# Baileys session tokens (Option B) – add as many as needed
WA_SESSION_COUNT=2
WA_TOKEN_1=your_ws_token_1
WA_TOKEN_2=your_ws_token_2

# Vercel environment flag (auto-set by Vercel)
VERCEL=1
